# Blend API — Environment Variables
# Copy this file to appsettings.Local.json or set via environment variables / secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
# HTTP port (default 8080 in containers, 5000 locally)
ASPNETCORE_URLS=http://+:5000

# ── Azure Cosmos DB ────────────────────────────────────────────────────────────
# Local emulator: use the connection string printed by `docker compose up`
CosmosDb__ConnectionString=AccountEndpoint=https://localhost:8081/;AccountKey=<your-key>
CosmosDb__DatabaseName=blend-dev

# ── Azure AI Search ────────────────────────────────────────────────────────────
AzureSearch__Endpoint=https://<your-search-service>.search.windows.net
AzureSearch__ApiKey=<your-search-api-key>
AzureSearch__IndexName=blend-index

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AzureStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
AzureStorage__ContainerName=blend-assets

# ── CORS ──────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=http://localhost:3000

# ── Authentication (Azure AD / Entra ID) ──────────────────────────────────────
AzureAd__TenantId=<your-tenant-id>
AzureAd__ClientId=<your-client-id>
AzureAd__ClientSecret=<your-client-secret>

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=blend-api
